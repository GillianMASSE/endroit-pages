---
const pathname = Astro.url.pathname;
function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---
<header>
  <div class="container nav-inner">
    <a class="nav-logo" href="/">
      <img src="/icon.png" alt="EnDroit" class="nav-mark" width="28" height="28" />
      <strong>En</strong><span>Droit</span>
    </a>

    <nav class="nav-links">
      <a href="/features" class:list={[{ active: isActive('/features') }]}>Features</a>
      <a href="/pricing" class:list={[{ active: isActive('/pricing') }]}>Pricing</a>
      <a href="/blog" class:list={[{ active: isActive('/blog') }]}>Blog</a>
      <a href="/about" class:list={[{ active: isActive('/about') }]}>About</a>
      <a href="/contact" class:list={[{ active: isActive('/contact') }]}>Contact</a>
    </nav>

    <div class="nav-cta">
      <a href="/signup" class="btn btn-secondary">Sign in</a>
      <a href="/signup" class="btn btn-primary">Get started</a>
    </div>

    <button class="nav-burger" id="navBurger" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav-mobile" id="navMobile">
    <a href="/features">Features</a>
    <a href="/pricing">Pricing</a>
    <a href="/blog">Blog</a>
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
    <a href="/signup" class="btn btn-primary" style="margin-top:12px">Get started</a>
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(10, 10, 15, 0.85);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 24px;
  }
  .nav-logo {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 20px;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.5px;
  }
  .nav-logo strong { color: var(--accent); }
  .nav-mark {
    display: block;
    width: 28px;
    height: 28px;
    border-radius: 8px;
    object-fit: cover;
    margin-right: 4px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
    flex: 1;
    justify-content: center;
  }
  .nav-links a {
    font-size: 14px;
    font-weight: 500;
    color: var(--muted);
    transition: color 0.15s;
  }
  .nav-links a:hover { color: var(--text); }
  .nav-links a.active { color: var(--accent); }

  .nav-cta {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .nav-burger {
    display: none;
    background: none;
    border: 0;
    width: 36px;
    height: 36px;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
    padding: 0;
  }
  .nav-burger span {
    display: block;
    height: 2px;
    width: 22px;
    background: var(--text);
    border-radius: 2px;
    margin: 0 auto;
  }

  .nav-mobile {
    display: none;
    flex-direction: column;
    gap: 14px;
    padding: 20px 24px;
    border-top: 1px solid var(--border);
    background: rgba(10, 10, 15, 0.98);
  }
  .nav-mobile a {
    font-size: 16px;
    font-weight: 600;
    color: var(--text);
  }
  .nav-mobile.open { display: flex; }

  @media (max-width: 900px) {
    .nav-links, .nav-cta { display: none; }
    .nav-burger { display: flex; }
  }
</style>

<script is:inline>
  const burger = document.getElementById('navBurger');
  const mobile = document.getElementById('navMobile');
  if (burger && mobile) {
    burger.addEventListener('click', () => mobile.classList.toggle('open'));
  }
</script>
