---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    slug: 'why-short-form-legal-education-matters',
    title: 'Why short-form legal education matters in 2026',
    excerpt: 'Vertical video is the new entry point for legal knowledge. Why creators should take it seriously — and why most law firms are missing it.',
    date: 'May 12, 2026',
    readingTime: '6 min read',
    category: 'Industry',
  },
  {
    slug: 'content-pipeline-respects-creators',
    title: 'Building a content pipeline that respects creators',
    excerpt: 'Most automation tools treat creators as content factories. We built EnDroit on the opposite premise: tooling should disappear so expertise can take center stage.',
    date: 'May 8, 2026',
    readingTime: '5 min read',
    category: 'Product',
  },
  {
    slug: 'hashtag-strategy-educational-tiktok',
    title: 'Hashtag strategy for educational TikTok in 2026',
    excerpt: 'The same hashtag list on TikTok, Instagram and YouTube is a rookie mistake. Here is the per-platform strategy that tripled our reach.',
    date: 'May 3, 2026',
    readingTime: '7 min read',
    category: 'Growth',
  },
  {
    slug: 'auto-synchronized-captions',
    title: 'How EnDroit auto-synchronizes captions at word level',
    excerpt: 'A look under the hood at the captioning pipeline. From audio waveform to readable groups of 4–5 words, with a 2.5-second display ceiling.',
    date: 'Apr 28, 2026',
    readingTime: '8 min read',
    category: 'Engineering',
  },
];
---
<Layout title="Blog — EnDroit" description="Insights for legal education creators: industry trends, product updates, growth strategy and engineering deep-dives.">

  <section class="page-hero">
    <div class="container">
      <div class="badge">Blog</div>
      <h1>The EnDroit journal.</h1>
      <p class="page-lead">
        Notes on short-form legal education, product decisions, growth strategy
        and the engineering behind making the law accessible.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="posts">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="post-card">
            <span class="post-category">{post.category}</span>
            <h3>{post.title}</h3>
            <p>{post.excerpt}</p>
            <div class="post-meta">
              <span>{post.date}</span>
              <span>·</span>
              <span>{post.readingTime}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero { padding: 72px 0 40px; }
  .page-lead { font-size: 18px; max-width: 580px; line-height: 1.65; }

  .posts {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }
  .post-card {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 28px;
    transition: border-color 0.15s, transform 0.15s;
  }
  .post-card:hover {
    border-color: var(--accent-glow);
    transform: translateY(-2px);
  }
  .post-category {
    display: inline-block;
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.4px;
    color: var(--accent);
    margin-bottom: 14px;
  }
  .post-card h3 {
    font-size: 20px;
    line-height: 1.3;
    margin-bottom: 10px;
    letter-spacing: -0.5px;
  }
  .post-card p {
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 16px;
  }
  .post-meta {
    display: flex;
    gap: 8px;
    font-size: 12px;
    color: var(--muted);
  }

  @media (max-width: 720px) {
    .posts { grid-template-columns: 1fr; }
  }
</style>
