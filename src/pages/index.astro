---
import Layout from '../layouts/Layout.astro';
---
<Layout title="EnDroit — Content platform for legal education creators">

  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <div class="badge">⚡ Beta open · Apply for access</div>
        <h1>
          Turn legal knowledge into <em>short-form video</em>
          that actually reaches people.
        </h1>
        <p class="hero-sub">
          EnDroit is the content platform built for legal education creators.
          Plan scripts, render captioned vertical videos, schedule across TikTok,
          Instagram Reels and YouTube Shorts — all in one workspace.
        </p>
        <div class="hero-cta">
          <a href="/signup" class="btn btn-primary">Get started — free</a>
          <a href="/features" class="btn btn-ghost">See features →</a>
        </div>
        <div class="hero-trust">
          Trusted by educators publishing on
          <span>TikTok</span> · <span>Instagram Reels</span> · <span>YouTube Shorts</span>
        </div>
      </div>

      <div class="hero-visual">
        <div class="phone">
          <div class="phone-screen">
            <div class="phone-caption">TON PATRON NE PEUT PAS<br/><em>FAIRE ÇA</em></div>
            <div class="phone-meta">
              <span class="phone-likes">❤️ 184K</span>
              <span class="phone-views">▶ 2.1M</span>
            </div>
          </div>
        </div>
        <div class="phone phone-back">
          <div class="phone-screen alt">
            <div class="phone-caption">15 000€<br/><em>D'AMENDE</em></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="logos">
    <div class="container">
      <div class="logos-row">
        <span class="logo-pill">TikTok Content API</span>
        <span class="logo-pill">Instagram Graph API</span>
        <span class="logo-pill">YouTube Data API v3</span>
        <span class="logo-pill">ElevenLabs Voice AI</span>
        <span class="logo-pill">Pexels Stock</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-label">Why EnDroit</div>
      <h2>Built for creators who make the law<br/>accessible to everyone</h2>
      <p class="section-lead">
        Lawyers, paralegals, law students and legal journalists use EnDroit to ship
        short-form educational content faster — without sacrificing accuracy.
      </p>

      <div class="features-grid">
        <div class="card feature">
          <div class="feature-icon">📝</div>
          <h3>Script studio</h3>
          <p>Draft, review and validate legal scripts with built-in source citations and disclaimer templates.</p>
        </div>
        <div class="card feature">
          <div class="feature-icon">🎬</div>
          <h3>Captioned renders</h3>
          <p>Generate 1080×1920 vertical videos with word-synced captions, animated scenes and royalty-free stock.</p>
        </div>
        <div class="card feature">
          <div class="feature-icon">📡</div>
          <h3>Multi-platform publish</h3>
          <p>Send the same video to TikTok, Instagram Reels and YouTube Shorts with platform-adapted hashtags.</p>
        </div>
        <div class="card feature">
          <div class="feature-icon">🗓️</div>
          <h3>Scheduled posts</h3>
          <p>Schedule publication times per platform and channel. Calendar view, drag-and-drop, time-zone aware.</p>
        </div>
        <div class="card feature">
          <div class="feature-icon">📊</div>
          <h3>Performance dashboard</h3>
          <p>Track views, retention and shares per video across platforms — pinpoint what resonates with your audience.</p>
        </div>
        <div class="card feature">
          <div class="feature-icon">👥</div>
          <h3>Multi-creator workspace</h3>
          <p>Invite collaborators, share script libraries, assign drafts. Each creator keeps their own connected accounts.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <section class="section">
    <div class="container">
      <div class="section-label">How it works</div>
      <h2>From topic idea to TikTok in under an hour</h2>

      <div class="steps">
        <div class="step">
          <span class="step-num">1</span>
          <div>
            <h3>Pick a topic</h3>
            <p>Choose from your editorial calendar or start a fresh draft. EnDroit suggests trending legal questions from your audience.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">2</span>
          <div>
            <h3>Write the script</h3>
            <p>The script editor enforces a viral hook, verified sources and a clear CTA. Disclaimers are added automatically.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">3</span>
          <div>
            <h3>Render the video</h3>
            <p>EnDroit produces a 60–70 second vertical video with synchronized captions, scene transitions and background footage.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">4</span>
          <div>
            <h3>Publish and track</h3>
            <p>Schedule or post immediately to all connected accounts. Track performance and iterate on what works.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <section class="section testimonials">
    <div class="container">
      <div class="section-label">From the field</div>
      <h2>What creators say</h2>

      <div class="testimonial-grid">
        <div class="card testimonial">
          <p>“I used to spend an entire afternoon on a single Reel. Now I plan, write and render four videos in the time it took me to do one — and the captions are finally readable.”</p>
          <div class="testimonial-author">
            <strong>Camille D.</strong>
            <span>Law student, Toulouse</span>
          </div>
        </div>
        <div class="card testimonial">
          <p>“The hashtag adaptation per platform is what hooked me. I was using the same 15 tags everywhere — EnDroit forced me to think differently and my reach on YouTube Shorts tripled.”</p>
          <div class="testimonial-author">
            <strong>Marc A.</strong>
            <span>Legal content creator, Paris</span>
          </div>
        </div>
        <div class="card testimonial">
          <p>“My team finally has a single calendar for the social side of the firm. Drafts, captions, scheduling — all in one place. The dashboard alone is worth it.”</p>
          <div class="testimonial-author">
            <strong>Sophie L.</strong>
            <span>Communications, mid-size law firm</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <section class="section cta">
    <div class="container">
      <div class="cta-box">
        <h2>Stop spending afternoons fighting CapCut.</h2>
        <p>Apply for beta access today. We review applications within 48 hours.</p>
        <div class="cta-buttons">
          <a href="/signup" class="btn btn-primary">Apply for beta access</a>
          <a href="/pricing" class="btn btn-secondary">See pricing</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ── */
  .hero {
    padding: 64px 0 80px;
    overflow: hidden;
    position: relative;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -200px; right: -200px;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(255,215,0,0.08), transparent 70%);
    pointer-events: none;
  }
  .hero .container {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 64px;
    align-items: center;
    position: relative;
  }
  .hero h1 { margin-top: 24px; margin-bottom: 24px; }
  .hero h1 em { font-style: normal; color: var(--accent); }
  .hero-sub {
    font-size: 18px;
    line-height: 1.65;
    max-width: 540px;
    margin-bottom: 36px;
  }
  .hero-cta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }
  .hero-cta .btn { padding: 14px 26px; font-size: 15px; }
  .hero-trust {
    font-size: 13px;
    color: var(--muted);
  }
  .hero-trust span {
    color: var(--text);
    font-weight: 600;
    margin: 0 2px;
  }

  /* ── Phone mockup ── */
  .hero-visual { position: relative; height: 480px; }
  .phone {
    position: absolute;
    width: 200px;
    height: 410px;
    border-radius: 32px;
    border: 1px solid var(--border-strong);
    background: linear-gradient(180deg, #1a1a24, #0a0a0f);
    box-shadow: 0 30px 60px -20px rgba(0,0,0,0.7), 0 0 0 6px rgba(255,255,255,0.03);
    padding: 12px;
    transform: rotate(-4deg);
    z-index: 2;
    left: 28%;
    top: 40px;
  }
  .phone-back {
    transform: rotate(7deg);
    z-index: 1;
    left: 4%;
    top: 28px;
    opacity: 0.85;
  }
  .phone-screen {
    width: 100%;
    height: 100%;
    border-radius: 22px;
    background: linear-gradient(180deg, #0f1923, #0a0f17);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 16px;
    text-align: center;
    position: relative;
  }
  .phone-screen.alt {
    background: linear-gradient(180deg, #1a1410, #100a06);
  }
  .phone-caption {
    font-size: 18px;
    font-weight: 900;
    letter-spacing: -0.5px;
    line-height: 1.15;
    color: #fff;
    text-shadow: 0 2px 14px rgba(0,0,0,0.5);
  }
  .phone-caption em {
    font-style: normal;
    color: var(--accent);
  }
  .phone-meta {
    position: absolute;
    bottom: 18px;
    left: 16px;
    right: 16px;
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: rgba(255,255,255,0.7);
    font-weight: 600;
  }

  /* ── Logos row ── */
  .logos {
    padding: 32px 0 0;
    border-bottom: 1px solid var(--border);
    padding-bottom: 32px;
  }
  .logos-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }
  .logo-pill {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--muted);
    font-size: 12px;
    font-weight: 600;
    padding: 7px 14px;
    border-radius: 8px;
  }

  /* ── Features grid ── */
  .section-lead {
    font-size: 17px;
    max-width: 620px;
    margin-bottom: 48px;
    margin-top: -8px;
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .feature-icon {
    font-size: 26px;
    margin-bottom: 14px;
  }
  .feature h3 { margin-bottom: 8px; }
  .feature p { font-size: 14px; line-height: 1.55; }

  /* ── Steps ── */
  .steps {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin-top: 24px;
  }
  .step {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 28px;
    display: flex;
    gap: 18px;
    align-items: flex-start;
  }
  .step-num {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: var(--accent-soft);
    border: 1px solid var(--accent-glow);
    color: var(--accent);
    font-size: 14px;
    font-weight: 800;
    flex-shrink: 0;
  }
  .step h3 { margin-bottom: 6px; }
  .step p { font-size: 14px; }

  /* ── Testimonials ── */
  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 32px;
  }
  .testimonial p {
    font-size: 15px;
    color: var(--text);
    line-height: 1.65;
    font-style: italic;
    margin-bottom: 24px;
  }
  .testimonial-author {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .testimonial-author strong {
    color: #fff;
    font-size: 14px;
  }
  .testimonial-author span {
    color: var(--muted);
    font-size: 13px;
  }

  /* ── CTA ── */
  .cta-box {
    background: linear-gradient(135deg, rgba(255,215,0,0.08), rgba(10,132,255,0.06));
    border: 1px solid var(--border-strong);
    border-radius: 24px;
    padding: 56px 48px;
    text-align: center;
  }
  .cta-box h2 { margin-bottom: 12px; }
  .cta-box p { font-size: 16px; margin-bottom: 28px; }
  .cta-buttons {
    display: inline-flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .cta-buttons .btn { padding: 14px 26px; font-size: 15px; }

  @media (max-width: 900px) {
    .hero .container { grid-template-columns: 1fr; gap: 40px; }
    .hero-visual { height: 360px; }
    .features-grid, .testimonial-grid { grid-template-columns: 1fr; }
    .steps { grid-template-columns: 1fr; }
  }
</style>
